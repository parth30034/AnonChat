# ── Backend (Railway) ────────────────────────────────────────────────────────

# Port Railway binds to (Railway injects this automatically)
PORT=3001

# Vercel frontend URL — set this after deploying the frontend
CLIENT_URL=https://your-app.vercel.app

# ── Frontend (Vercel) ────────────────────────────────────────────────────────

# Railway backend URL — set this after deploying the backend
VITE_SOCKET_URL=https://your-server.up.railway.app
